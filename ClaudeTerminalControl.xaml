<UserControl x:Class="ClaudeVS.ClaudeTerminalControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsfx="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:local="clr-namespace:ClaudeVS"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="400"
             Background="#1e1e1e"
             Foreground="#d4d4d4"
             KeyboardNavigation.TabNavigation="Local"
             KeyboardNavigation.DirectionalNavigation="Contained"
             KeyboardNavigation.ControlTabNavigation="Local"
             GotFocus="ClaudeTerminalControl_GotFocus">
    <UserControl.Resources>
        <Style x:Key="DarkButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3f3f46"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LightButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2d7d2d"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#444444"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3f3f46"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3a9a3a"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LightToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#2d7d2d"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#C0C0C0"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#3a9a3a"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border x:Name="ToolbarBorder" Grid.Row="0"
                Background="#0c0c0c"
                BorderBrush="Black"
                BorderThickness="0"
                Padding="4">
            <StackPanel Orientation="Horizontal">
            <ToggleButton x:Name="MicButton"
                    Content="🎤 Mic"
                    Padding="4,2"
                    FontSize="12"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Left"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#1e1e1e"
                    BorderThickness="0"
                    Focusable="False"
                    IsTabStop="False"
                    Style="{StaticResource DarkToggleButtonStyle}"
                    Checked="MicButton_Checked"
                    Unchecked="MicButton_Unchecked"/>

            <Button x:Name="ChangeCommandButton"
                    Content="⚙ Change Agent"
                    Padding="4,2"
                    FontSize="12"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Left"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#1e1e1e"
                    BorderThickness="0"
                    Focusable="False"
                    IsTabStop="False"
                    Style="{StaticResource DarkButtonStyle}"
                    Click="ChangeCommandButton_Click"/>

            <Button x:Name="RestartAgentButton"
                    Content="🔄 Restart Agent"
                    Padding="4,2"
                    FontSize="12"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Left"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#1e1e1e"
                    BorderThickness="0"
                    Focusable="False"
                    IsTabStop="False"
                    Style="{StaticResource DarkButtonStyle}"
                    Click="RestartAgentButton_Click"/>

            <Button x:Name="ThemeButton"
                    Content="🎨 Theme"
                    Padding="4,2"
                    FontSize="12"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Left"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#1e1e1e"
                    BorderThickness="0"
                    Focusable="False"
                    IsTabStop="False"
                    Style="{StaticResource DarkButtonStyle}"
                    Click="ThemeButton_Click"/>

            <Button x:Name="FontSizeButton"
                    Content="🔤 Font Size"
                    Padding="4,2"
                    FontSize="12"
                    Margin="0"
                    HorizontalAlignment="Left"
                    Background="#1e1e1e"
                    Foreground="#d4d4d4"
                    BorderBrush="#1e1e1e"
                    BorderThickness="0"
                    Focusable="False"
                    IsTabStop="False"
                    Style="{StaticResource DarkButtonStyle}"
                    Click="FontSizeButton_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="TerminalBorder" Grid.Row="1" HorizontalAlignment="Stretch" Background="#1e1e1e">
            <local:EmbeddedConsoleHost x:Name="ConsoleHost"
                                       Focusable="True"/>
        </Border>
    </Grid>
</UserControl>
